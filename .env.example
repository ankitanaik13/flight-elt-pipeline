# ============================================================
# Airflow Configuration
# ============================================================

# UID/GID for the Airflow process inside Docker containers
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Executor type — LocalExecutor is sufficient for single-node setups
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Set to False to keep the UI clean without sample DAGs
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Fernet key for encrypting sensitive connection data in the Airflow DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here

# New DAGs are paused by default — must be manually enabled
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True

# Prevent concurrent DAG runs for idempotency
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1

# SQLAlchemy connection string for the Airflow metadata database
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow_db

# Secret key for the Airflow webserver session signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here

# ============================================================
# PostgreSQL Configuration (Airflow metadata DB)
# ============================================================

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow_db

# ============================================================
# Pipeline Data Warehouse Configuration
# ============================================================

# Name of the database used to store flight data (created via init script)
PIPELINE_DB=pipeline_db

# Hostname of the postgres service (matches Docker Compose service name)
PIPELINE_DB_HOST=postgres

PIPELINE_DB_PORT=5432
PIPELINE_DB_USER=airflow
PIPELINE_DB_PASSWORD=airflow

# Full SQLAlchemy connection string for the pipeline warehouse
PIPELINE_CONN_STRING=postgresql+psycopg2://airflow:airflow@postgres:5432/pipeline_db

# ============================================================
# BTS Data Source URLs
# ============================================================

# Monthly BTS On-Time Performance ZIP file (change year/month as needed)
BTS_FLIGHT_URL=https://transtats.bts.gov/PREZIP/On_Time_Reporting_Carrier_On_Time_Performance_1987_present_2024_1.zip

# Local paths where the ZIP and extracted CSV will be saved inside the container
BTS_LOCAL_ZIP=/tmp/bts_flights_2024_01.zip
BTS_LOCAL_CSV=/tmp/bts_flights_2024_01.csv

# ============================================================
# Lookup Data URLs (OpenFlights — public, no auth required)
# ============================================================

AIRPORTS_URL=https://raw.githubusercontent.com/jpatokal/openflights/master/data/airports.dat
AIRLINES_URL=https://raw.githubusercontent.com/jpatokal/openflights/master/data/airlines.dat

# ============================================================
# dbt Configuration
# ============================================================

# Path to the dbt project directory inside the Airflow container
DBT_PROJECT_DIR=/opt/airflow/dbt_project

# Path to the dbt profiles.yml directory
DBT_PROFILES_DIR=/opt/airflow/dbt_project
